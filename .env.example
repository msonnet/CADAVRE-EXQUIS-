# ── Supabase (mode multijoueur en ligne) ──────────────────
# Récupérables dans Supabase → Settings → API
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Supabase service role (pour le cron cleanup côté serveur) ──
# Supabase → Settings → API → service_role key (NE PAS exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic Claude (voix intérieures, correction d'accords, prompt visuel) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── fal.ai (génération d'illustration + avatar) ──
FAL_KEY=...

# ── Vercel Cron (protège l'endpoint /api/cleanup) ──
# Générer un secret aléatoire : openssl rand -hex 32
# Configurer dans Vercel → Settings → Environment Variables
CRON_SECRET=...
